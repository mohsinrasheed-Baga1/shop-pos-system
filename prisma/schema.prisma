// Prisma schema for Shop POS System

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String
  phone        String?
  role         String   @default("CASHIER") // ADMIN | MANAGER | CASHIER
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sales        Sale[]
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  icon      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id           String   @id @default(cuid())
  name         String
  barcode      String   @unique
  barcodeType  String   @default("CODE128") // CODE128 | EAN13 | COMPANY (scanned)
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  costPrice    Float    @default(0)   // purchase price
  salePrice    Float    @default(0)   // selling price
  unit         String   @default("piece") // piece | kg | gram | litre | ml | dozen
  stock        Float    @default(0)
  minStock     Float    @default(0)   // low-stock alert threshold
  taxRate      Float    @default(0)   // percent
  hasBarcode   Boolean  @default(true) // false for loose items (auto-generated)
  image        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  saleItems    SaleItem[]
  stockLogs    StockLog[]
}

model Sale {
  id           String     @id @default(cuid())
  invoiceNo    String     @unique
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  customerName String?
  customerPhone String?
  subtotal     Float      @default(0)
  taxTotal     Float      @default(0)
  discount     Float      @default(0)
  total        Float      @default(0)
  paidAmount   Float      @default(0)
  change       Float      @default(0)
  paymentMethod String    @default("CASH") // CASH | CARD | MOBILE
  status       String     @default("COMPLETED") // COMPLETED | RETURNED
  originalSaleId String?  // if this is a return record, links to original sale
  note         String?
  createdAt    DateTime   @default(now())
  items        SaleItem[]
  returns      SaleReturn[]
}

model SaleReturn {
  id           String   @id @default(cuid())
  saleId       String
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  userId       String
  amount       Float
  reason       String?
  restocked    Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model SaleItem {
  id         String  @id @default(cuid())
  saleId     String
  sale       Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  name       String
  barcode    String
  price      Float
  costPrice  Float
  quantity   Float
  unit       String
  taxRate    Float
  lineTotal  Float
}

model StockLog {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String   // PURCHASE | SALE | ADJUSTMENT | RETURN
  quantity  Float
  note      String?
  createdAt DateTime @default(now())
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerCard {
  id             String            @id @default(cuid())
  cardNumber     String            @unique
  name           String
  phone          String?
  address        String?
  type           String            @default("REGULAR") // REGULAR | WHOLESALE
  balance        Float             @default(0)
  totalPurchases Float             @default(0)
  totalPaid      Float             @default(0)
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  transactions   CardTransaction[]
}

model CardTransaction {
  id          String        @id @default(cuid())
  cardId      String
  card        CustomerCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  type        String // PURCHASE | PAYMENT | DEPOSIT | WITHDRAW
  amount      Float         @default(0)
  description String?
  saleId      String?
  createdAt   DateTime      @default(now())
}

model Settings {
  id            String   @id @default("shop")
  shopName      String   @default("My Shop")
  subName       String?
  logo          String?
  shopAddress   String?
  shopPhone     String?
  currency      String   @default("Rs")
  taxEnabled    Boolean  @default(false)
  defaultTax    Float    @default(0)
  receiptFooter String?
  invoicePrefix String   @default("INV")
  printerWidth  Int      @default(58)
  backupPasswordHash String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
