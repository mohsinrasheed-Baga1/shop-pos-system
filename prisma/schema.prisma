// Prisma schema for Shop POS System

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String
  phone        String?
  role         String   @default("CASHIER")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sales        Sale[]
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  icon      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Vendor {
  id          String   @id @default(cuid())
  name        String
  companyName String?
  phone       String?
  address     String?
  note        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
}

model Product {
  id              String   @id @default(cuid())
  name            String
  barcode         String   @unique
  barcodeType     String   @default("CODE128")
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  vendorId        String?
  vendor          Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  costPrice       Float    @default(0)
  salePrice       Float    @default(0)
  wholesalePrice  Float    @default(0)
  unit            String   @default("piece")
  stock           Float    @default(0)
  storeStock      Float    @default(0)
  minStock        Float    @default(0)
  taxRate         Float    @default(0)
  expiryDate      DateTime?
  manufacturingDate DateTime?
  hasBarcode      Boolean  @default(true)
  image           String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  saleItems       SaleItem[]
  stockLogs       StockLog[]
  storeTxns       StoreTransaction[]
}

model Sale {
  id            String     @id @default(cuid())
  invoiceNo     String     @unique
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  cardId        String?
  card          CustomerCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)
  customerName  String?
  customerPhone String?
  subtotal      Float      @default(0)
  taxTotal      Float      @default(0)
  discount      Float      @default(0)
  total         Float      @default(0)
  paidAmount    Float      @default(0)
  change        Float      @default(0)
  paymentMethod String     @default("CASH")
  saleType      String     @default("RETAIL")
  status        String     @default("COMPLETED")
  originalSaleId String?
  note          String?
  createdAt     DateTime   @default(now())
  items         SaleItem[]
  returns       SaleReturn[]
}

model SaleReturn {
  id           String   @id @default(cuid())
  saleId       String
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  userId       String
  amount       Float
  reason       String?
  restocked    Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model SaleItem {
  id         String  @id @default(cuid())
  saleId     String
  sale       Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  name       String
  barcode    String
  price      Float
  costPrice  Float
  quantity   Float
  unit       String
  taxRate    Float
  lineTotal  Float
}

model StockLog {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String
  quantity  Float
  note      String?
  createdAt DateTime @default(now())
}

model CustomerCard {
  id             String   @id @default(cuid())
  cardNumber     String   @unique
  name           String
  phone          String?
  address        String?
  type           String   @default("REGULAR")
  balance        Float    @default(0)
  totalPurchases Float    @default(0)
  totalPaid      Float    @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  transactions   CardTransaction[]
  sales          Sale[]
}

model CardTransaction {
  id          String   @id @default(cuid())
  cardId      String
  card        CustomerCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  type        String
  amount      Float
  description String?
  saleId      String?
  createdAt   DateTime @default(now())
}

model StoreTransaction {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        String
  quantity    Float
  note        String?
  createdAt   DateTime @default(now())
}

model Settings {
  id            String   @id @default("shop")
  shopName      String   @default("My Shop")
  subName       String?
  logo          String?
  shopAddress   String?
  shopPhone     String?
  currency      String   @default("Rs")
  taxEnabled    Boolean  @default(false)
  defaultTax    Float    @default(0)
  receiptFooter String?
  invoicePrefix String   @default("INV")
  printerWidth  Int      @default(58)
  backupPasswordHash String?
  // Multi-computer sharing: "local" | "host" | "client"
  shareMode     String   @default("local")
  // When shareMode = "client", the network DB path (e.g. \\HOST\ShopPOS\pos.db)
  dbNetworkPath String?
  // Google Drive backup integration
  googleClientId     String?
  googleClientSecret String?
  googleRefreshToken String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
